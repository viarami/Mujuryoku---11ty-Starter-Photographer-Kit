{% from "components/demo/macros.njk" import featureCard, themeCard, stepItem, pageCard, resourceCard, specGroup %}

<section class="demo-hero">
    <div class="container">
        <h1 class="demo-logo">{{ demo.hero.logo }}</h1>
        <p class="demo-tagline">{{ demo.hero.tagline }}</p>
        <p class="demo-description">{{ demo.hero.description }}</p>

        <div class="demo-hero-badges">
            {% for badge in demo.hero.badges %}
                {% uiBadge badge, "demo-badge" %}
            {% endfor %}
        </div>

        <div class="demo-hero-actions">
            {% for action in demo.hero.actions %}
                {% uiButton action.label, action.href, action.variant, action.className %}
            {% endfor %}
        </div>

        <nav class="demo-jump-links" aria-label="Overview Sections">
            {% for jumpLink in demo.hero.jumpLinks %}
                <a href="{{ jumpLink.href }}" class="demo-jump-link">{{ jumpLink.label }}</a>
            {% endfor %}
        </nav>
    </div>
</section>

<section id="overview" class="demo-section">
    <div class="container">
        {% uiSectionHeader demo.sections.overview.title, demo.sections.overview.description, "demo-section-header" %}

        <div class="demo-overview-grid">
            {% for item in demo.overview %}
                <article class="demo-overview-card">
                    <p class="demo-overview-value">{{ item.value }}</p>
                    <h3>{{ item.label }}</h3>
                    <p>{{ item.description }}</p>
                </article>
            {% endfor %}
        </div>
    </div>
</section>

<section class="demo-section demo-section-alt">
    <div class="container">
        <div class="demo-intro">
            <div class="demo-intro-content">
                <h2>{{ demo.intro.title }}</h2>
                {% for paragraph in demo.intro.paragraphs %}
                    <p>{{ paragraph }}</p>
                {% endfor %}
            </div>
            <div class="demo-intro-badge">
                <h3>{{ demo.intro.badgeTitle }}</h3>
                <p>{{ demo.intro.badgeText }}</p>
            </div>
        </div>
    </div>
</section>

<section id="features" class="demo-section">
    <div class="container">
        {% uiSectionHeader demo.sections.features.title, demo.sections.features.description, "demo-section-header" %}

        <div class="demo-features-grid">
            {% for feature in demo.features %}
                {{ featureCard(feature) }}
            {% endfor %}
        </div>
    </div>
</section>

<section id="themes" class="demo-section demo-section-alt">
    <div class="container">
        {% uiSectionHeader demo.sections.themes.title, demo.sections.themes.description, "demo-section-header" %}

        <div class="demo-themes-grid">
            {% for themeItem in demo.themes %}
                {{ themeCard(themeItem) }}
            {% endfor %}
        </div>
    </div>
</section>

<section class="demo-section">
    <div class="container">
        {% uiSectionHeader demo.sections.media.title, demo.sections.media.description, "demo-section-header" %}
        <div class="demo-media-grid">
            {% if demo.mediaGallery.length %}
                {% for mediaItem in demo.mediaGallery %}
                    <figure class="demo-media-card">
                        {% responsiveImage
                            mediaItem.src,
                            mediaItem.alt,
                            "(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
                        %}
                        <figcaption>{{ mediaItem.category }}</figcaption>
                    </figure>
                {% endfor %}
            {% else %}
                <article class="demo-media-empty">
                    <h3>No extra demo images found</h3>
                    <p>Add files to <code>demo-images/</code> and this section will populate automatically.</p>
                </article>
            {% endif %}
        </div>
    </div>
</section>

<section class="demo-section demo-section-alt">
    <div class="container">
        {% uiSectionHeader demo.sections.structure.title, demo.sections.structure.description, "demo-section-header" %}

        <div class="demo-resources-grid">
            {% for resource in demo.projectStructure %}
                {{ resourceCard(resource) }}
            {% endfor %}
        </div>
    </div>
</section>

<section id="quickstart" class="demo-section">
    <div class="container">
        {% uiSectionHeader demo.sections.quickStart.title, demo.sections.quickStart.description, "demo-section-header" %}

        {% uiCallout demo.quickStart.callout.title, "tip" %}
            {% for paragraph in demo.quickStart.callout.paragraphs %}
                <p>{{ paragraph }}</p>
            {% endfor %}
        {% enduiCallout %}

        <div class="demo-quickstart">
            <div class="demo-steps">
                {% for step in demo.quickStart.steps %}
                    {{ stepItem(step, loop.index0) }}
                {% endfor %}
            </div>

            {% uiTerminal "Quick Start Commands" %}
{{ demo.quickStart.commandBlock }}
            {% enduiTerminal %}
        </div>
    </div>
</section>

<section id="pages" class="demo-section demo-section-alt">
    <div class="container">
        {% uiSectionHeader demo.sections.pages.title, demo.sections.pages.description, "demo-section-header" %}

        <div class="demo-pages-grid">
            {% for pageItem in demo.samplePages %}
                {{ pageCard(pageItem) }}
            {% endfor %}
        </div>
    </div>
</section>

<section id="specs" class="demo-section">
    <div class="container">
        {% uiSectionHeader demo.sections.specs.title, demo.sections.specs.description, "demo-section-header" %}

        <div class="demo-specs-grid">
            {% for specGroupItem in demo.specs %}
                {{ specGroup(specGroupItem) }}
            {% endfor %}
        </div>
    </div>
</section>

<section class="demo-cta">
    <div class="container">
        <h2>{{ demo.cta.title }}</h2>
        <p>{{ demo.cta.description }}</p>
        <div class="demo-cta-actions">
            {% for action in demo.cta.actions %}
                {% uiButton action.label, action.href, action.variant %}
            {% endfor %}
        </div>
    </div>
</section>
