---
title: Home
layout: base.njk
eleventyNavigation:
  key: Home
  order: 1
---

{% if site.isDemoBuild and not site.isDev %}
<section class="section section-muted">
    <div class="container">
        <div class="cta-content">
            <h1 class="cta-title">Redirecting to Demo</h1>
            <p class="cta-description">The published demo build opens directly on the demo route.</p>
            <a href="./demo/" class="btn btn-primary">Open Demo</a>
        </div>
    </div>
</section>
<script>
    window.location.replace('./demo/');
</script>
{% else %}

<!-- Hero Section -->
<section class="hero section">
    <div class="container">
        <div class="hero-content">
            <div class="hero-text">
                <h1 class="hero-title">Capturing Moments</h1>
                <p class="hero-description">Professional photography that tells your story. Specializing in portrait, event, and landscape photography.</p>
                <div class="hero-actions">
                    <a href="/portfolio/" class="btn btn-primary">View Portfolio</a>
                    <a href="/contact/" class="btn btn-outline">Get in Touch</a>
                </div>
            </div>
            <div class="hero-image">
                {% responsiveImage "/assets/images/hero.jpg", "Photography portfolio showcase", "(max-width: 768px) 100vw, 50vw", { loading: "eager" } %}
            </div>
        </div>
    </div>
</section>

<!-- Featured Work Section -->
<section class="featured section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Featured Work</h2>
            <p class="section-description">A selection of recent projects and favorite shots</p>
        </div>

        <div class="gallery-grid">
            {% for item in portfolio.items | slice(0, 6) %}
                <div class="gallery-item">
                    <a href="/portfolio/" class="gallery-link">
                        {% responsiveImage item.image, item.title, "(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw" %}
                        <div class="gallery-overlay">
                            <span class="gallery-title">{{ item.title }}</span>
                        </div>
                    </a>
                </div>
            {% endfor %}
        </div>

        <div class="section-footer">
            <a href="/portfolio/" class="btn btn-outline">View All Work</a>
        </div>
    </div>
</section>

<!-- About Section -->
<section class="about section section-muted">
    <div class="container">
        <div class="about-content">
            <div class="about-image">
                {% responsiveImage "/assets/images/photographer.jpg", "Photographer portrait", "(max-width: 768px) 100vw, 50vw" %}
            </div>
            <div class="about-text">
                <h2 class="about-title">About the Photographer</h2>
                <p class="about-description">With over 10 years of experience capturing life's most precious moments, I bring a unique perspective and artistic vision to every project. My work spans from intimate portraits to grand landscapes, always with an emphasis on authentic storytelling.</p>
                <p class="about-description">Based in {{ metadata.contact.address }}, I work with clients across the region to create lasting memories through the art of photography.</p>
                <a href="/about/" class="btn btn-primary">Learn More</a>
            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section class="services section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Services</h2>
            <p class="section-description">Professional photography services tailored to your needs</p>
        </div>

        <div class="services-grid">
            <div class="service-card card">
                <div class="service-icon">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                </div>
                <h3 class="service-title">Portraits</h3>
                <p class="service-description">Professional portraits for individuals, couples, and families. Capturing your authentic self.</p>
            </div>

            <div class="service-card card">
                <div class="service-icon">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                </div>
                <h3 class="service-title">Events</h3>
                <p class="service-description">Comprehensive event coverage for weddings, corporate events, and special occasions.</p>
            </div>

            <div class="service-card card">
                <div class="service-icon">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                    </svg>
                </div>
                <h3 class="service-title">Commercial</h3>
                <p class="service-description">High-quality commercial photography for products, brands, and marketing materials.</p>
            </div>
        </div>
    </div>
</section>

<!-- Testimonials Section -->
<section class="testimonials section section-muted">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">What Clients Say</h2>
        </div>

        {% include "components/testimonials.njk" %}
    </div>
</section>

<!-- Contact CTA Section -->
<section class="cta section">
    <div class="container">
        <div class="cta-content">
            <h2 class="cta-title">Let's Create Something Beautiful Together</h2>
            <p class="cta-description">Ready to capture your next special moment? Get in touch to discuss your project.</p>
            <a href="/contact/" class="btn btn-primary">Contact Now</a>
        </div>
    </div>
</section>

{% endif %}
