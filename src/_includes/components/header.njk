<header class="header">
    <div class="container">
        <div class="header-content">
            <!-- Logo -->
            <a href="{{ '/' | url }}" class="logo">
                <h1 class="logo-text">{{ metadata.title }}</h1>
            </a>

            <!-- Navigation -->
            <nav class="nav" id="main-nav">
                <ul class="nav-list">
                    {% for item in collections.all | eleventyNavigation %}
                        <li class="nav-item">
                            <a href="{{ item.url | url }}" class="nav-link">{{ item.title }}</a>
                        </li>
                    {% endfor %}
                </ul>
            </nav>

            <!-- Mobile menu button -->
            <button class="mobile-menu-button" id="mobile-menu-button" aria-label="Toggle menu">
                <span class="menu-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="3" y1="12" x2="21" y2="12"></line>
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <line x1="3" y1="18" x2="21" y2="18"></line>
                    </svg>
                </span>
                <span class="close-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </span>
            </button>
        </div>
    </div>

    <!-- Mobile menu -->
    <div class="mobile-menu" id="mobile-menu">
        <div class="mobile-menu-content">
            <ul class="mobile-nav-list">
                {% for item in collections.all | eleventyNavigation %}
                    <li class="mobile-nav-item">
                        <a href="{{ item.url | url }}" class="mobile-nav-link">{{ item.title }}</a>
                    </li>
                {% endfor %}
            </ul>
        </div>
    </div>

    <!-- Mobile menu overlay -->
    <div class="mobile-menu-overlay" id="mobile-menu-overlay"></div>
</header>